RIGEL_SERVICE_NAME=rigel-jd-browser-collector
RIGEL_HTTP_PORT=18086
RIGEL_LOG_LEVEL=info
RIGEL_JD_BROWSER_COLLECTOR_MODE=mock
RIGEL_JD_FALLBACK_TO_MOCK=true
RIGEL_JD_HEADLESS=true
RIGEL_JD_NAV_TIMEOUT_MS=30000
RIGEL_JD_USER_AGENT=
RIGEL_JD_COOKIE=
RIGEL_JD_COOKIE_FILE=
RIGEL_JD_STORAGE_STATE_PATH=state/jd-storage-state.json
RIGEL_JD_REFERER=https://www.jd.com/
RIGEL_JD_BASE_URL=https://search.jd.com
RIGEL_JD_SELF_OPERATED_ONLY=true
RIGEL_JD_SCREENSHOT_ON_RISK=false
RIGEL_JD_SCREENSHOT_DIR=screenshots
